{
    "name": "pizzubot",
    "version": "1.0.2",
    "keywords": [
        "bot",
        "ts"
    ],
    "license": "GPL-3.0-only",
    "author": "alexatsu",
    "type": "module",
    "main": "src/index.ts",
    "scripts": {
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "typecheck": "tsc --noEmit",
        "start": "tsx src/index.ts",
        "deploy:db": "pnpm exec prisma migrate deploy && pnpm exec prisma generate"
    },
    "dependencies": {
        "@discordjs/opus": "^0.10.0",
        "@discordjs/voice": "^0.19.0",
        "@google/genai": "^1.41.0",
        "@hono/node-server": "^1.19.9",
        "@prisma/adapter-pg": "^7.7.0",
        "@prisma/client": "^7.7.0",
        "@snazzah/davey": "^0.1.9",
        "discord.js": "^14.25.1",
        "dotenv": "^17.2.3",
        "hono": "^4.11.6",
        "opus-decoder": "^0.7.11",
        "opusscript": "^0.1.1",
        "pg": "^8.20.0",
        "prism-media": "^1.3.5"
    },
    "devDependencies": {
        "@eslint/js": "^9.39.2",
        "@types/node": "^25.0.10",
        "@types/pg": "^8.20.0",
        "eslint": "^9.39.2",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-perfectionist": "^5.4.0",
        "prettier": "^3.8.1",
        "prisma": "^7.7.0",
        "tsx": "^4.21.0",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.54.0"
    }
}
